  tmiText: {fileID: 501512268}
  tmis:
  - "\uAE30\uD68D\uC790 \uC708\uD2F0\uB294 \uB2E4\uB9AC\uAC00 1\uC790\uB85C \uCC22\uC5B4\uC9C4\uB2E4"
  - "\uD574\uC870\uC758 \uC791\uC5C5\uC2E4\uC740 \uC5B8\uC81C\uB098 \uC0AC\uB78C\uC774
    \uC788\uB2E4"
  - "\uC774 \uD300\uC758 \uAC1C\uBC1C\uC790\uB294 \uC774 \uD300\uC774 \uC870\uACF5
    \uCC98\uC74C\uC774\uB2E4"
  - "\uD0B9\uB9BC\uBC14\uC758 \uC758\uC790\uB294 \uBD80\uB7EC\uC838 \uAE30\uB300\uAE30
    \uD798\uB4E4\uB2E4"
  - "\uAE30\uD68D\uC790 \uC708\uD2F0\uB294 \uBE44\uD0B4 \uC131\uB300\uBAA8\uC0AC\uB97C
    \uC798\uD55C\uB2E4"
  - "\uC791\uAC00 \uBD88\uBA74\uC99D\uC740 \uC0AC\uC2E4 \uC798 \uC794\uB2E4"
  - "ui \uC791\uC5C5\uC790 \uBC31\uD63C\uC740 \uC7A0\uB4E4\uAE30 \uAE4C\uC9C0 1\uC2DC\uAC04
    \uC774\uC0C1 \uAC78\uB9B0\uB2E4"
  - "\uCD1D\uAD04 \uACE0\uB4F1\uC5B4\uB538\uAE30\uD30C\uB974\uD398\uB294 10\uBD84\uB9CC\uC5D0
    \uC798 \uC218 \uC788\uB2E4"
  - "\uACE0\uB4F1\uC5B4\uB538\uAE30\uD30C\uB974\uD398\uB294 [\uACE0\uB4F1\uC5B4\uB538\uAE30\uD30C\uC544\uB974\uD398]\uB85C
    \uBC1C\uC74C\uD55C\uB2E4"
  - "\uCD1D\uAD04\uC740 \uAD34\uC2DD\uC774\uB984\uC744 \uC798 \uC9D3\uB294\uB2E4"
  - "\uC774 \uAC8C\uC784\uC758 \uCD1D\uAD04\uC740 \uC0AC\uB0B4\uAD34\uC870\uC9C1\uC758
    \uC218\uC7A5\uC774\uB2E4"
  - "\uD300\uC6D0 \uC911 \uC5B4\uB9B4 \uB54C \uC81C\uD2F0\uC5D0 \uD55C\uC774 \uB9FA\uD600
