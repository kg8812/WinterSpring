  m_text: "\U0001F310\uCD1D\uD300\uC7A5 : \uC6B0\uC5C9\uC0C8\r\n\r\n\u231B PM : \uBD88\uBA74\uC99D\r\n\U0001F9FE
    \uCD1D\uAD04 : \uC6B0\uC5C9\uC0C8, \uACE0\uB4F1\uC5B4\uB538\uAE30\uD30C\uB974\uD398\r\n\r\n\U0001F48E
    \uD300\uC7A5\uAE09 \uB9AC\uC2A4\uD2B8\r\n\U0001F48E \uC544\uD2B8\uD300\uC7A5
    (AD) \uC2E0\uC0AC\uBD80\uC5C9\uC774\r\n\U0001F48E \uAE30\uD68D\uD300\uC7A5 \uACE0\uB4F1\uC5B4\uB538\uAE30\uD30C\uB974\uD398\r\n\U0001F48E
    \uB808\uBCA8\uB514\uC790\uC778 \uD300\uC7A5 \uC774\uB8E8\uB9AC\uC57C\r\n\U0001F48E
    \uAC1C\uBC1C\uD300\uC7A5 \uC5D0\uD53C\uC2A4\r\n\U0001F48E \uC2A4\uD30C\uC778\uD300\uC7A5
    \uADF8\uB298\r\n\U0001F48E OST\uD300\uC7A5 \uACE0\uACE0\uB85C\r\n\U0001F48E SFX\uD300\uC7A5
    \uC774\uB7C9\r\n\U0001F48E \uB514\uC790\uC778 \uB9AC\uB4DC \uAC2D\uAC2D\uC774\r\n\r\n\uC2A4\uB561:
    \uB355\uC0C1, \uC54C\uD2F0\r\n\r\n-----------------------\r\n\u270D\uFE0F \uAE30\uD68D\uD300
    \r\n\r\n\u270D\uFE0F \uBA54\uC778 : \uACE0\uB4F1\uC5B4\uB538\uAE30\uD30C\uB974\uD398
    \u3163 Winti\r\n\r\n\u270D\uFE0F \uD300\uC6D0 : Splatted \u3163 \uCFC4\uD050\uBA00
    \u3163 \uC774\uAC15\uCC2C \\n\u3163 \uC564\uD2F0\uC2A4\r\n\r\n----------------------\r\n\r\n\u270D\uFE0F
    \uB808\uBCA8\uB514\uC790\uC778\uD300 \r\n\r\n\u270D\uFE0F \uD300\uC7A5 : \uC774\uB8E8\uB9AC\uC57C\r\n\r\n\u270D\uFE0F
    \uD300\uC6D0 : C2dar \u3163 \uAFC0\uC8FD\uCC3D \u3163 \uCEEC\uB7EC\uD050\uBE0C
    \u3163 \r\n\r\n----------------------\r\n\r\n\U0001F955 \uAC1C\uBC1C\uD300 \r\n\r\n\U0001F955
    \uD300\uC7A5 : \uC5D0\uD53C\uC2A4\r\n\r\n\U0001F955 \uD300\uC6D0: \uCC28\uBAFC
    \u3163 \uC791\uC740\uC124\uD0D5\r\n\r\n---------------------\r\n\r\n\U0001F3A8
    \uC544\uD2B8\uD300\r\n\r\n\U0001F3A8 \uD300\uC7A5 : \uC2E0\uC0AC\uBD80\uC5C9\uC774\r\n\r\n\U0001F419 
    \uD06C\uB9AC\uCCD0 \uD300\uC6D0 : \uAD00\uBCC4\u3163\uBC24\uD61C\uB791\u3163\uACF54\uC911\u3163\uD3EC\uB808\uC778\u3163400\r\n\r\n\U0001F5FA\uFE0F
    \uBC30\uACBD \uD300\uC6D0 : \uC81C\uADDC\u3163\uC591\uCA29\u3163\uB5A1\uC78E\u3163BreadOK\\n\u3163JJACKJACK
    \u3163\uC591\uC11C\uC9C4\r\n\r\n\U0001F9C3 \uC544\uC774\uD15C \uD300\uC6D0 :
    \uAC10\uC790\uACE0\uB4F1\uC5B4\u31635858\u3163\uC2A4\uD0C0\uCF58\u3163\uB85C\uC548\\n\u3163\uADF8\uAC70\uB9DE\uC74C\u3163\uC62C\uBE8C\uBBF8
    l \uADC0\uB9C8\uAC1C\r\n\r\n\U0001F3A8 \uB77C\uC774\uD305 \uC544\uD2F0\uC2A4\uD2B8
    : ddooly\r\n\r\n\U0001F3A8 VFX : \uC790\uAD6C\uBBF8 \u3163\uC7AC\uC6B1\u3163\uC21C\uBB49\r\n\r\n\U0001F3A8
    TA : \uC544\uD50C\uB77C \r\n\r\n\U0001F3A8 \uCEF7\uC52C \uD300\uC6D0 : LICIA
    \u3163 \uB514 \u3163\uB77C\uC784\uB300\uB9C8\uC655\u3163\uCC38\uCE58\uD584\uC2A4\uD130\\n\u3163\uB9BC\u3163\uC2E0\uC0AC\uBD80\uC5C9\uC774\u3163\uB9AC\uCE58\uC0C1\r\n\r\n\U0001F3A8
    \uC2A4\uD30C\uC778 \uBD84\uC808 : \uC138\uB808\uC2A4 \uC140\uB77C \u3163 \uB098\uD14C\r\n\r\n\n\r\n\U0001F5FF
    \uCE90\uB9AD\uD130 \r\n\r\n\U0001F5FF \uB514\uC790\uC778 \uC2E0\uC0AC\uBD80\uC5C9\uC774\u3163\uC6B0\uC5C9\uC0C8\u3163LICIA
    \r\n\r\n\U0001F5FF \uC6D0\uD654(\uB9AC\uC18C\uC2A4) : \uC6B0\uC5C9\uC0C8\r\n\r\n\U0001F4F8
    LIVE2D :  Housecat \r\n\r\n-------------------\r\n\U0001F39E\uFE0F \uC2A4\uD30C\uC7782D
    \uD300\r\n\r\n\U0001F39E\uFE0F\uD300\uC7A5 : \uADF8\uB298\r\n\r\n\U0001F39E\uFE0F
    \uD300\uC6D0 :  \uC6E8\uC778\uC774 \u3163 \uBC15\uD2B8\uB7F4 \u3163 RES \u3163
    \uC2DD\uC6A9\uB6A4\uAE30 \\n\u3163\uACF5\uBC31\u3163\uB2E4\uC774\uC2AC\u3163
    \uB9C8\uB85D\r\n\r\n--------------------\r\n\r\n\U0001F3B5 OST\uD300\r\n\r\n\U0001F3B5
    \uD300\uC7A5 : \uACE0\uACE0\uB85C\r\n\r\n\U0001F3B5 \uBCF4\uCEEC : \uC774\uCC59\uC774\r\n\r\n\U0001F3B5
    \uD300\uC6D0 : \uC5D0\uC2A4\uD504\uB808\uC18C \u3163 YoonTT \u3163 \uD0B9\uB9BC\uBC14\r\n\r\n\U0001F3B5
    \uBBF9\uC2F1 : \uC9C0\uD55C\r\n\r\n\U0001F3B5 \uC5D4\uB529\uACE1 \uBCF4\uCEEC
    : \uC774\uCC59\uC774\r\n\r\n\U0001F3B5 \uC5D4\uB529\uACE1 \uD300\uC6D0 : \uC57D\uBE64\uAE30\uD0C0
    \u3163 \uC5D0\uC2A4\uD504\uB808\uC18C \u3163 \uC9C0\uD55C\r\n\r\n-------------------\r\n\r\n\U0001F3B6
    SFX\uD300\r\n\r\n\U0001F3B6 \uD300\uC7A5 : \uC774\uB7C9\r\n\r\n\U0001F3B6 \uD300\uC6D0
    : TICTAP \u3163 \uD53C\uC82F\uC2A4\uD53C\uB2C8 \u3163 \uD2F0\uCF58\r\n\r\n-------------------\r\n\r\n\U0001F4DF
    \uB514\uC790\uC778\uD300\r\n\r\n\U0001F4DF \uD300\uC7A5 : \uCFE0\uD0A4\uB458\uAE30\r\n\r\n\U0001F4DF
    \uD300\uC6D0 : \uAC2D\uAC2D\uC774\u3163\uB098\uB978\r\n\r\n---------------------\r\n\r\n\U0001F680
    \uB0B4\uBD80\uD14C\uC2A4\uD305 \uD300\r\n\r\n\U0001F680  \uD300\uC6D0 : Halcion
