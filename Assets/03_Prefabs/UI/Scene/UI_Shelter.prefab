  m_text: "\uADFC\uBC29\uC758 \uC801\uB4E4\uC744 \uD5A5\uD574 \uB3CC\uC9C4\uD558\uB294
    \uAC15\uC544\uC9C0\uB5BC\uB97C 5\uB9C8\uB9AC \uC18C\uD658\uD569\uB2C8\uB2E4. 
    \uC774 \uAC15\uC544\uC9C0\uB5BC\uB4E4\uC740 \uCCAB \uCDA9\uB3CC\uD558\uB294 \uB300\uC0C1\uC5D0
    \uCD5C\uCD08 100% \uD53C\uD574\uB97C \uC785\uD788\uACE0 \uC774\uD6C4\uC5D0 \uCDA9\uB3CC\uD558\uB294
    \uB300\uC0C1\uB4E4\uC5D0\uAC8C\uB294 20%\uC529 \uAC10\uC18C\uB41C \uD53C\uD574\uB97C
